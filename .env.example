# Copy to .env.local and fill values. Never commit real secrets.

# --- 약물 분석 (/api/analyze): 웹 검색 + AI (로컬 DB는 AI 보강 기준선) ---
# MEDICATION_WEB_SEARCH=0 이면 웹 검색 비활성 (선택)
# SERPER_API_KEY=   Google 검색 (선택, https://serper.dev)
# TAVILY_API_KEY=   Tavily 검색 (선택)
MEDICATION_WEB_SEARCH=
SERPER_API_KEY=
TAVILY_API_KEY=
# AI_PROVIDER=auto | gemini | cerebras  (auto = Gemini 우선, 실패 시 Cerebras)
AI_PROVIDER=auto
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama3.1-70b
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1

# --- 약물 상호작용 (/api/interactions): 근거 요약 후 선택적 LLM 설명 ---
# INTERACTIONS_LLM_ORDER=cerebras,gemini  (미설정 시 AI_PROVIDER와 동일한 우선순위 규칙)
INTERACTIONS_LLM_ORDER=

# 상용/임상 상호작용 API (선택). 미설정 시 이 경로는 사용하지 않음.
COMMERCIAL_DI_API_BASE_URL=
COMMERCIAL_DI_API_KEY=
COMMERCIAL_DI_TIMEOUT_MS=8000

# --- 영양 제품 (/api/nutrition/product): USDA FoodData Central ---
# 미설정 시 비프로덕션에서는 DEMO_KEY 사용 가능. 프로덕션에서는 설정 권장.
# https://fdc.nal.usda.gov/api-key-signup/
USDA_FDC_API_KEY=
